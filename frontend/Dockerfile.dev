# Development Dockerfile for AstrID Frontend
FROM node:20-alpine

WORKDIR /app

# Install su-exec for user switching
RUN apk add --no-cache su-exec

# Copy package files
COPY package*.json ./
COPY next.config.js ./
COPY tailwind.config.js ./
COPY postcss.config.js ./
COPY tsconfig.json ./

# Install all dependencies
RUN npm install

# Copy source code
COPY app/ ./app/
COPY components/ ./components/
COPY public/ ./public/

# Ensure training-data placeholder JSONs exist so /training-data/*.json return 200 (page handles empty data)
RUN mkdir -p /app/public/training-data && \
  echo '{"total_sne":0,"processed":0,"failed":0,"real_samples":0,"bogus_samples":0,"total_samples":0}' > /app/public/training-data/triplets-summary.json && \
  echo '{"total_sne":0,"processed":0,"failed":0,"real_samples":0,"bogus_samples":0,"total_samples":0}' > /app/public/training-data/augmented-summary.json && \
  echo '[]' > /app/public/training-data/real-metadata.json && \
  echo '[]' > /app/public/training-data/bogus-metadata.json

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Set ownership
RUN chown -R nextjs:nodejs /app

# Switch to non-root user
USER nextjs

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1

# Run development server
CMD ["npm", "run", "dev"]
